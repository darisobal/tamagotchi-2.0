# Create a free project at https://supabase.com, then paste:
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Run supabase/schema.sql in the Supabase SQL editor once.
# Enable email confirmation: npm run enable:email-confirmation
# (requires SUPABASE_ACCESS_TOKEN from https://supabase.com/dashboard/account/tokens)

# In-app purchase (pet restart after death) — consumable product id:
#   com.tamagotchi.app.restart
# Create it in App Store Connect + Google Play Console at €1.00.
# Real StoreKit / Play Billing requires a development build (not Expo Go).
# Web / Expo Go uses the mock checkout with test card 4242 4242 4242 4242.
